---
import * as Shell from '@blueprint/ui/shell';
import { PortalNav } from '@/components/PortalNav';
// ArchaeologyChat is suppressed by default at the operator-decision layer.
// Wave 17 (the bc-promo-rules amendment commit 74fa02f) closes the leak at
// stamp time (WORKER_URL blanked) and at component time (renders a disabled
// "substrate not configured" button when WORKER_URL is empty). This gate adds
// the third layer — even with WORKER_URL configured, the widget mounts only
// when the operator has explicitly flipped ARCHAEOLOGY_READY to true.
// Flip to true ONLY when ALL of the following are met:
//   1. blueprint.yml sets `archaeology.enabled: true`
//   2. `bash tools/archaeology/scaffold.sh` has deployed the project's Worker + ingested sources
//   3. WORKER_URL in src/components/ArchaeologyChat.tsx points at THIS project's substrate
// See docs/archaeology-substrate-pattern.md + METHODOLOGY.md § "Stage S-A".
// Wave 18 (2026-05-27).
const ARCHAEOLOGY_READY = false;
// Conditional import keeps the disabled bundle clean (build-time tree-shake).
const ArchaeologyChat = ARCHAEOLOGY_READY
  ? (await import('@/components/ArchaeologyChat')).ArchaeologyChat
  : null;
import '@/styles/global.css';

export interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;
const fullTitle = title === 'blueprint-platform' ? title : `${title} — blueprint-platform`;
---
<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Inter+Display:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <Shell.Root>
      <Shell.Header>
        <PortalNav client:load currentPath={currentPath} />
      </Shell.Header>
      <Shell.Main>
        <slot />
      </Shell.Main>
      <Shell.Footer>
        <div class="flex flex-col items-start justify-between gap-2 sm:flex-row sm:items-center">
          <p>
            <span class="font-heading font-semibold text-foreground">blueprint-platform</span> · Blueprint productized — the methodology as a team-adoptable, portable platform.
          </p>
          <p class="font-mono text-[11px] uppercase tracking-wide text-contrast-400">
            <a href="https://github.com/nino-chavez/blueprint-platform" target="_blank" rel="noreferrer" class="hover:text-brand">github ↗</a>
          </p>
        </div>
      </Shell.Footer>
    </Shell.Root>
    {ARCHAEOLOGY_READY && ArchaeologyChat && <ArchaeologyChat client:idle pageContext={currentPath} />}
  </body>
</html>
