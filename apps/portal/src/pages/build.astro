---
import Layout from '@/layouts/Layout.astro';
import { loadAdrCatalog } from '@/lib/content';

const adrs = loadAdrCatalog();
const recentAdrs = adrs.slice(0, 8);
const REPO = 'https://github.com/nino-chavez/blueprint-platform/blob/main';

interface BuildSurface {
  title: string;
  description: string;
  href: string;
  meta: string;
}

const SURFACES: BuildSurface[] = [
  {
    title: 'API reference',
    description: 'REST endpoints, scopes, webhooks, error shapes. OpenAPI spec is the contract; admin clients + SDKs both generate from it.',
    href: `${REPO}/apps/api/openapi.yaml`,
    meta: '→ apps/api/openapi.yaml',
  },
  {
    title: 'React SDK',
    description: 'Hooks + components for subscription PDPs, cart, and account portal. Hooks-only entry for headless setups.',
    href: `${REPO}/packages/react`,
    meta: '→ @blueprint/react',
  },
  {
    title: 'Catalyst SDK',
    description: 'BigCommerce Catalyst-specific bindings — server actions, BCSF queries, route handlers pre-wired for subscriptions.',
    href: `${REPO}/packages/storefront-catalyst`,
    meta: '→ @blueprint/storefront-catalyst',
  },
  {
    title: 'Web Component',
    description: 'Framework-agnostic <bc-sub-widget> custom element for Stencil and other non-React storefronts.',
    href: `${REPO}/packages/storefront-webcomponent`,
    meta: '→ @blueprint/storefront-webcomponent',
  },
  {
    title: 'Component library',
    description: 'Portal/shell + commerce primitives. React + Tailwind + Radix + CVA. Storefront-kit-inspired.',
    href: 'https://subs-portal-storybook.pages.dev',
    meta: '→ Storybook',
  },
  {
    title: 'Design tokens',
    description: 'OKLCH-based tokens, framework-agnostic CSS variables. Tailwind preset + raw CSS exports.',
    href: `${REPO}/packages/design-tokens`,
    meta: '→ @blueprint/design-tokens',
  },
];
---
<Layout title="Build" description="Integrate it. API, ADRs, SDKs, components.">
  <header class="mb-10 max-w-3xl">
    <p class="mb-2 font-mono text-xs uppercase tracking-wide text-info">Build</p>
    <h1 class="mb-3 font-heading text-4xl font-semibold leading-tight tracking-tight">
      Integrate it.
    </h1>
    <p class="text-lg leading-relaxed text-contrast-500">
      Everything you need to integrate subscriptions into a Catalyst storefront, a Stencil theme, or a custom headless setup. Each card links to source.
    </p>
  </header>

  <section class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {SURFACES.map((s) => (
      <a
        href={s.href}
        target="_blank"
        rel="noreferrer"
        class="group block rounded-lg border border-contrast-200 bg-background p-5 transition-colors hover:border-brand/60"
      >
        <h3 class="mb-1 font-heading text-base font-semibold tracking-tight text-foreground group-hover:text-brand">
          {s.title}
        </h3>
        <p class="mb-3 text-sm leading-relaxed text-contrast-500">{s.description}</p>
        <p class="font-mono text-[10px] uppercase tracking-wide text-contrast-400">{s.meta}</p>
      </a>
    ))}
  </section>

  <section class="mt-12">
    <header class="mb-4 flex items-end justify-between">
      <div>
        <h2 class="font-heading text-2xl font-semibold tracking-tight">Latest decisions</h2>
        <p class="mt-1 text-sm text-contrast-500">
          {adrs.length} ratified ADRs · most recent first
        </p>
      </div>
      <a
        href={`${REPO}/docs/decisions/`}
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono text-[11px] uppercase tracking-wide text-brand hover:underline"
      >
        full index →
      </a>
    </header>
    <ol class="divide-y divide-contrast-100 rounded-lg border border-contrast-200 bg-background">
      {recentAdrs.map((adr) => (
        <li class="flex items-center gap-4 px-4 py-3 transition-colors duration-fast ease-standard hover:bg-contrast-100/40">
          <span class="w-14 shrink-0 font-mono text-xs font-medium uppercase tracking-wide text-contrast-400">
            ADR-{String(adr.number).padStart(4, '0')}
          </span>
          <a
            href={`${REPO}/docs/decisions/${adr.filename}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 text-sm text-foreground hover:text-brand"
          >
            {adr.title}
          </a>
        </li>
      ))}
    </ol>
  </section>
</Layout>
